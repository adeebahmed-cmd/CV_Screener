[Unit]
Description=HR Screener - CV Ranking Tool
After=network.target

[Service]
Type=simple
User=itadmin
WorkingDirectory=/home/itadmin/HR_Screener/backend
ExecStart=/home/itadmin/HR_Screener/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
